{
  "// DESIGN": [
    "3層設計:",
    "1. Read許可 + Edit/Write禁止 → pbxproj, storyboard, xib等（構造理解OK、編集NG）",
    "2. Read禁止 → バイナリ、ビルド成果物、シークレット",
    "3. 全許可 → .swift, .md, .yml等のソースコード",
    "",
    "⚠ 既知の問題: permissions.deny の Read/Edit/Write は",
    "GitHub Issue #6631, #6699, #27040 で未機能バグ報告あり。",
    "Bashコマンド経由のアクセスも防げない。",
    "CLAUDE.md での明示的指示と併用推奨。"
  ],

  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Write(*.swift)",
      "Edit(*.swift)",
      "Write(*.md)",
      "Edit(*.md)",
      "Write(*.yml)",
      "Edit(*.yml)",
      "Write(*.yaml)",
      "Edit(*.yaml)",
      "Write(*.json)",
      "Edit(*.json)",
      "Write(*.plist)",
      "Edit(*.plist)",
      "Write(*.xcconfig)",
      "Edit(*.xcconfig)",
      "Write(*.entitlements)",
      "Edit(*.entitlements)",
      "Write(*.metal)",
      "Edit(*.metal)",
      "Bash(git:*)",
      "Bash(swift:*)",
      "Bash(xcodebuild:*)",
      "Bash(xcrun:*)",
      "Bash(xcodegen:*)",
      "Bash(tuist:*)",
      "Bash(pod:*)",
      "Bash(swiftlint:*)",
      "Bash(swiftformat:*)"
    ],

    "deny": [
      "// ━━━ 第2層: 編集禁止（読み取りは許可）━━━",
      "Edit(*.pbxproj)",
      "Write(*.pbxproj)",
      "Edit(*.storyboard)",
      "Write(*.storyboard)",
      "Edit(*.xib)",
      "Write(*.xib)",
      "Edit(*.xcdatamodeld/**)",
      "Write(*.xcdatamodeld/**)",
      "Edit(*.xcassets/**)",
      "Write(*.xcassets/**)",
      "Edit(*.xcstrings)",
      "Write(*.xcstrings)",
      "Edit(*.xcworkspace/**)",
      "Write(*.xcworkspace/**)",

      "// ━━━ 第1層: シークレット（読み取りも禁止）━━━",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/*.p12)",
      "Read(./**/*.p8)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)",
      "Read(./**/*.cer)",
      "Read(./**/*.mobileprovision)",
      "Read(./**/*.provisionprofile)",
      "Read(./**/GoogleService-Info.plist)",
      "Read(./**/Secrets.xcconfig)",
      "Read(./secrets/**)",
      "Read(./credentials/**)",

      "// ━━━ 第1層: バイナリ・ビルド成果物 ━━━",
      "Read(./DerivedData/**)",
      "Read(./build/**)",
      "Read(./.build/**)",
      "Read(./**/*.ipa)",
      "Read(./**/*.dSYM)",
      "Read(./**/*.dSYM.zip)",
      "Read(./**/*.xcarchive)",
      "Read(./**/*.app)",
      "Read(./**/*.framework)",
      "Read(./**/*.xcframework)",
      "Read(./**/*.a)",
      "Read(./**/*.dylib)",
      "Read(./**/*.xcresult)",
      "Read(./**/*.metallib)",
      "Read(./**/*.nib)",
      "Read(./**/*.storyboardc)",
      "Read(./**/*.mom)",
      "Read(./**/*.momd)",

      "// ━━━ 第1層: メディア ━━━",
      "Read(./**/*.png)",
      "Read(./**/*.jpg)",
      "Read(./**/*.jpeg)",
      "Read(./**/*.gif)",
      "Read(./**/*.webp)",
      "Read(./**/*.heic)",
      "Read(./**/*.svg)",
      "Read(./**/*.mp4)",
      "Read(./**/*.mov)",
      "Read(./**/*.mp3)",
      "Read(./**/*.wav)",
      "Read(./**/*.ttf)",
      "Read(./**/*.otf)",
      "Read(./**/*.lottie)",

      "// ━━━ 第1層: 依存関係 ━━━",
      "Read(./Pods/**)",
      "Read(./Carthage/**)",
      "Read(./SourcePackages/**)",
      "Read(./node_modules/**)",

      "// ━━━ 危険なコマンド ━━━",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)"
    ]
  }
}
